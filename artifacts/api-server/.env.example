# API server configuration for local/manual pilot validation.
# Do not expose these values in VITE_* browser environment variables.
PORT=3000
VEROXA_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Default is no proxy trust. If deploying behind a known proxy, set only explicit
# trusted proxy hops/subnets such as loopback, linklocal, uniquelocal, or CIDRs.
VEROXA_TRUST_PROXY=false
VEROXA_PILOT_MOMO_HOUSE_PASSWORD=replace_with_server_side_momo_house_pilot_secret
VEROXA_PILOT_TEAM_FARAZ_PASSWORD=replace_with_server_side_team_faraz_pilot_secret

# Optional abuse-protection tuning for /api/pilot-access.
VEROXA_PILOT_ACCESS_RATE_LIMIT_WINDOW_MS=900000
VEROXA_PILOT_ACCESS_RATE_LIMIT_MAX=8
