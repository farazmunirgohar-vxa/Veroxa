VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Preview-only placeholder login credentials are intentionally omitted.
# Do not set VITE_VEROXA_DEV_* credentials in public staging or production builds.

# Real Login V1 manual pilot access endpoint. This value is safe for the browser
# because the endpoint checks pilot credentials server-side. Use an absolute API
# server URL if the API is deployed separately from the Vite frontend.
VITE_VEROXA_PILOT_ACCESS_ENDPOINT=/api/pilot-access
